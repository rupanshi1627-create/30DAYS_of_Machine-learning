import numpy as np
import matplotlib.pyplot as plt
#NumPy = numbers + arrays ke liye optimized library

#CELL 2: Raw Data
age = np.array([20, 25, 30, 35, 40])
salary = np.array([20000, 40000, 60000, 80000, 100000])
print("Age:", age)
print("Salary:", salary)

#Min-Max Scaling
# Min-Max Scaling function
def min_max_scale(x):
    return (x - np.min(x)) / (np.max(x) - np.min(x))

age_scaled = min_max_scale(age)
salary_scaled = min_max_scale(salary)

print("Scaled Age:", age_scaled)
print("Scaled Salary:", salary_scaled)
#why we used define function for scaling? because we can reuse it for any dataset and it keeps our code clean and organized.
#Min-Max Scaling is a technique that transforms features to a specific range, typically [0, 1]. It is calculated using the formula:
#X_scaled = (X - X_min) / (X_max - X_min)


#before Scaling Plot
plt.scatter(age, salary)

plt.scatter(age, salary)
plt.title("Before Scaling")
plt.xlabel("Age")
plt.ylabel("Salary")
plt.show()

plt.scatter(age_scaled, salary_scaled)
plt.title("After Scaling")
plt.xlabel("Age (Scaled)")
plt.ylabel("Salary (Scaled)")
plt.show()

x = age_scaled
y = salary_scaled

w = 0
b = 0
lr = 0.1
n = len(x)

for i in range(10):
    y_pred = w * x + b
    error = y_pred - y
    
    dw = np.sum(error * x) / n
    db = np.sum(error) / n
    
    w = w - lr * dw
    b = b - lr * db
    
    print("Iteration", i+1, "w:", w, "b:", b)


